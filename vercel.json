:root{--navy:#12233f;--blue:#2463eb;--green:#1f9d68;--cream:#f7f5ef;--text:#172033;--muted:#667085;--line:#dbe3ed;--white:#fff}*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;color:var(--text);background:#fff}a{text-decoration:none;color:inherit}button,input,select,textarea{font:inherit}.site-header{position:sticky;top:0;z-index:20;display:flex;align-items:center;justify-content:space-between;min-height:76px;padding:14px clamp(20px,5vw,72px);background:rgba(255,255,255,.94);border-bottom:1px solid rgba(18,35,63,.08);backdrop-filter:blur(14px)}.brand{display:flex;align-items:center;gap:10px;color:var(--navy);font-size:20px;font-weight:850}.brand-mark{display:grid;place-items:center;width:39px;height:39px;border-radius:12px 12px 18px 12px;color:#fff;background:linear-gradient(145deg,var(--blue),var(--green));box-shadow:0 8px 20px rgba(36,99,235,.2)}nav{display:flex;gap:28px;color:#475467;font-size:14px;font-weight:700}.button{display:inline-flex;align-items:center;justify-content:center;min-height:50px;padding:0 24px;border:0;border-radius:12px;color:#fff;background:var(--blue);font-weight:800;cursor:pointer;box-shadow:0 10px 24px rgba(36,99,235,.21)}.button-small{min-height:43px;padding:0 18px;font-size:14px}.button-secondary{color:var(--navy);background:#fff;border:1px solid var(--line);box-shadow:none}.hero{min-height:660px;padding:88px clamp(22px,7vw,108px);display:grid;grid-template-columns:1.08fr .92fr;gap:68px;align-items:center;background:radial-gradient(circle at 85% 18%,#dcecff 0,transparent 29%),linear-gradient(135deg,#f9fbff,#f7f5ef)}.eyebrow{margin:0;color:var(--blue);font-size:12px;font-weight:850;letter-spacing:.15em}.hero h1{margin:16px 0 20px;color:var(--navy);font-size:clamp(48px,6vw,78px);line-height:.98;letter-spacing:-.055em}.lead{max-width:700px;color:#536177;font-size:19px;line-height:1.7}.hero-actions{display:flex;gap:12px;margin-top:31px}.trust-row{display:flex;flex-wrap:wrap;gap:22px;margin-top:24px;color:#4b596d;font-size:13px;font-weight:750}.preview-card{position:relative;padding:30px;border-radius:28px;background:rgba(255,255,255,.94);box-shadow:0 32px 80px rgba(18,35,63,.16);transform:rotate(1deg)}.preview-card:before{content:"";position:absolute;inset:16px -20px -20px 20px;z-index:-1;border-radius:28px;background:linear-gradient(135deg,#cde0ff,#dff5e9)}.preview-top{display:flex;justify-content:space-between;color:#7a8699;font-size:11px;font-weight:850;letter-spacing:.12em}.preview-top strong{color:var(--green)}.preview-card h2{margin:24px 0 12px;color:var(--navy)}.progress{height:8px;margin-bottom:24px;border-radius:99px;background:#edf1f5;overflow:hidden}.progress span{display:block;width:55%;height:100%;background:linear-gradient(90deg,var(--blue),var(--green))}.preview-step{display:flex;gap:14px;padding:15px 0;border-top:1px solid #edf0f4;color:#8a94a4}.preview-step b{display:grid;place-items:center;flex:0 0 34px;height:34px;border-radius:50%;background:#eff2f6}.preview-step strong,.preview-step small{display:block}.preview-step strong{color:#354156}.preview-step small{margin-top:4px}.preview-step.done b{color:var(--green);background:#ddf7ea}.preview-step.active b{color:var(--blue);background:#dfeaff}.planner-section,.results-section,.how-section,.pros-section{padding:88px clamp(22px,7vw,108px)}.section-heading{max-width:720px;margin:0 auto 42px;text-align:center}.section-heading.left{margin-left:0;text-align:left}.section-heading h2,.result-head h2,.cta h2{margin:10px 0 12px;color:var(--navy);font-size:clamp(34px,4vw,52px);letter-spacing:-.04em}.section-heading>p:last-child,.result-head p{color:var(--muted);line-height:1.7}.planner-card{max-width:980px;margin:auto;padding:32px;display:grid;grid-template-columns:1fr 1fr;gap:22px;border:1px solid var(--line);border-radius:24px;background:#fff;box-shadow:0 24px 70px rgba(18,35,63,.08)}label{display:flex;flex-direction:column;gap:8px;color:#344054;font-size:14px;font-weight:800}input,select,textarea{width:100%;padding:15px 16px;border:1px solid #cfd7e3;border-radius:12px;background:#fbfcfe;color:#182230;outline:none}input:focus,select:focus,textarea:focus{border-color:var(--blue);box-shadow:0 0 0 4px rgba(36,99,235,.09)}textarea{min-height:112px;resize:vertical}label small{color:#98a2b3;font-weight:500}.full-width{grid-column:1/-1}.results-section{background:#f6f8fb}.hidden{display:none!important}.result-head{max-width:1150px;margin:0 auto 28px;display:grid;grid-template-columns:1fr 320px;gap:35px;align-items:end}.jurisdiction-card{padding:22px;border:1px solid var(--line);border-radius:18px;background:#fff}.jurisdiction-card small,.jurisdiction-card strong,.jurisdiction-card span{display:block}.jurisdiction-card small{color:var(--muted)}.jurisdiction-card strong{margin:8px 0 3px;color:var(--navy);font-size:21px}.jurisdiction-card span{color:#667085;font-size:14px}.notice{max-width:1150px;margin:0 auto 24px;padding:16px 18px;border:1px solid #f2dd90;border-radius:14px;background:#fff7db;color:#694600;line-height:1.55}.result-grid{max-width:1150px;margin:auto;display:grid;grid-template-columns:1.25fr .75fr;gap:24px}.panel{padding:28px;border:1px solid var(--line);border-radius:20px;background:#fff}.panel h3{margin-top:0;color:var(--navy)}.steps-list{padding:0;margin:0;list-style:none}.steps-list li{display:flex;gap:14px;padding:14px 0;border-top:1px solid #edf0f4}.steps-list span{display:grid;place-items:center;flex:0 0 30px;height:30px;border-radius:50%;color:#fff;background:var(--blue);font-size:13px;font-weight:800}.steps-list p{margin:4px 0;color:#4d5a6e;line-height:1.55}.check-list{padding:0;list-style:none;color:#48566a}.check-list li{padding:11px 0;border-top:1px solid #edf0f4}.source-box{margin-top:24px;padding:18px;border-radius:14px;background:#f3f6fb}.source-box p{color:var(--muted);line-height:1.55}.ai-box{max-width:1150px;margin:24px auto 0;padding:22px;display:flex;align-items:center;justify-content:space-between;gap:20px;border:1px solid #cfe0ff;border-radius:18px;background:#edf4ff}.ai-box p{margin:5px 0 0;color:#5f6f85}.ai-box span{padding:8px 11px;border-radius:99px;background:#fff;color:var(--blue);font-size:11px;font-weight:850;white-space:nowrap}.how-section{background:var(--cream)}.feature-grid{max-width:1200px;margin:auto;display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.feature-grid article{min-height:220px;padding:25px;border:1px solid rgba(18,35,63,.08);border-radius:20px;background:#fff}.feature-grid b{color:var(--blue);font-size:13px}.feature-grid h3{margin-top:30px;color:var(--navy)}.feature-grid p{color:var(--muted);line-height:1.65}.pros-section{text-align:center}.pro-grid{max-width:1100px;margin:0 auto 28px;display:grid;grid-template-columns:repeat(3,1fr);gap:18px;text-align:left}.pro-grid article{display:flex;gap:16px;padding:22px;border:1px solid var(--line);border-radius:18px}.avatar{display:grid;place-items:center;flex:0 0 48px;height:48px;border-radius:14px;color:#fff;background:linear-gradient(145deg,var(--blue),var(--green));font-weight:900}.pro-grid small{color:#b7791f;font-size:10px;font-weight:850;letter-spacing:.1em}.pro-grid h3{margin:6px 0;color:var(--navy)}.pro-grid p{color:var(--muted)}.success-message{color:var(--green);font-weight:750}.cta{margin:0 clamp(22px,7vw,108px) 80px;padding:50px;display:flex;align-items:center;justify-content:space-between;gap:30px;border-radius:28px;color:#fff;background:linear-gradient(120deg,var(--navy),#1d4f91)}.cta .eyebrow{color:#89b6ff}.cta h2{max-width:820px;color:#fff}.cta p{color:#c8d6e8}.button-light{color:var(--navy);background:#fff;white-space:nowrap}footer{padding:45px clamp(22px,7vw,108px);color:#aebbd0;background:#0d192d}footer .brand{color:#fff}footer p{margin:14px 0 26px}@media(max-width:900px){nav{display:none}.hero{grid-template-columns:1fr;padding-top:64px}.preview-card{max-width:620px}.planner-card,.result-head,.result-grid{grid-template-columns:1fr}.feature-grid,.pro-grid{grid-template-columns:1fr 1fr}.cta{align-items:flex-start;flex-direction:column}}@media(max-width:620px){.site-header>.button{display:none}.hero{min-height:auto;padding:58px 20px}.hero h1{font-size:46px}.hero-actions{flex-direction:column}.planner-section,.results-section,.how-section,.pros-section{padding:68px 20px}.planner-card{padding:20px;grid-template-columns:1fr}.full-width{grid-column:auto}.feature-grid,.pro-grid{grid-template-columns:1fr}.ai-box{align-items:flex-start;flex-direction:column}.cta{margin:0 20px 55px;padding:32px 24px}}
